# Django
DJANGO_SETTINGS_MODULE=hoopci.settings.development
DJANGO_SECRET_KEY=changeme-generate-a-real-secret-key

# Base de données PostgreSQL
DB_NAME=hoopci
DB_USER=hoopci_user
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Production seulement
ALLOWED_HOSTS=hoopci.ci,www.hoopci.ci
CORS_ALLOWED_ORIGINS=https://hoopci.ci,https://www.hoopci.ci

# Email (production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# GeniusPay (https://pay.genius.ci) - laisser vide en dev pour le mode simulation
GENIUSPAY_API_KEY=
GENIUSPAY_API_SECRET=
GENIUSPAY_BASE_URL=https://pay.genius.ci
FRONTEND_URL=http://localhost:5173
TARIF_PUBLICATION_TOURNOI=5000
