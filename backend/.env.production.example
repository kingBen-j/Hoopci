# HoopCI — configuration production (copier vers .env sur le VPS et remplir)
# ATTENTION : DJANGO_SETTINGS_MODULE doit aussi être exporté dans le shell pour
# les commandes manage.py (voir DEPLOIEMENT.md) — gunicorn l'utilise via wsgi.py.
DJANGO_SETTINGS_MODULE=hoopci.settings.production

# Générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

ALLOWED_HOSTS=hoopci.ci,www.hoopci.ci
CORS_ALLOWED_ORIGINS=https://hoopci.ci,https://www.hoopci.ci

# PostgreSQL
DB_NAME=hoopci
DB_USER=hoopci
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis — db 0 pour Celery, db 1 pour le cache Django
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# Redirections du checkout GeniusPay vers le site
FRONTEND_URL=https://hoopci.ci
TARIF_PUBLICATION_TOURNOI=5000

# GeniusPay — clés live du compte marchand (https://pay.genius.ci)
# Sans clés, l'initiation de paiement renvoie 503 (la simulation est réservée au DEBUG)
GENIUSPAY_BASE_URL=https://pay.genius.ci
GENIUSPAY_API_KEY=
GENIUSPAY_API_SECRET=

# E-mails transactionnels (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Supervision des erreurs (optionnel — laisser vide pour désactiver)
SENTRY_DSN=
